# Only Clipper - Rebuilt Core Engine Environment Configuration
# Copy this file to .env for local development.

# --- API KEYS ---
# Set at least GROQ_API_KEY or OPENAI_API_KEY (or both)
GROQ_API_KEY=
OPENAI_API_KEY=

# --- ENVIRONMENT CONFIG ---
ENVIRONMENT=development
BASE_URL=http://localhost:8000
DATABASE_URL=sqlite:///storage/clipper.db

# --- FRONTEND PUBLIC VARIABLES ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_DEV_MODE=true

# --- TIMEOUTS ---
AI_API_TIMEOUT_SECONDS=120
AI_API_MAX_RETRIES=2
FFMPEG_TIMEOUT_SECONDS=300
FFPROBE_TIMEOUT_SECONDS=30
THUMBNAIL_TIMEOUT_SECONDS=30

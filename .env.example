# Only Clipper — Production Environment Configuration
# Copy this file to .env for local development.

# --- API KEYS ---
GROQ_API_KEY=
OPENAI_API_KEY=

# --- QUEUE / REDIS ---
REDIS_URL=redis://localhost:6379

# --- ENVIRONMENT CONFIG ---
ENVIRONMENT=development
BASE_URL=http://localhost:8000
DATABASE_URL=postgresql://clipper:clipper@localhost:5432/clipper

# --- STORAGE ---
# "local" = filesystem (dev), "supabase" = Supabase Storage (prod)
STORAGE_BACKEND=local
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=clips

# --- FRONTEND PUBLIC VARIABLES ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_DEV_MODE=true

# --- TIMEOUTS ---
AI_API_TIMEOUT_SECONDS=120
AI_API_MAX_RETRIES=2
FFMPEG_TIMEOUT_SECONDS=300
FFPROBE_TIMEOUT_SECONDS=30
THUMBNAIL_TIMEOUT_SECONDS=30

# --- DOWNLOAD ---
# Default quality: proxy (720p) | full (1080p)
DEFAULT_DOWNLOAD_QUALITY=proxy
